---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const preselectedCategory = Astro.url.searchParams.get('category') || '';

let categories: any[] = [];
try {
  const res = await fetch(new URL('/api/forum/categories', Astro.url));
  if (res.ok) {
    const data = await res.json();
    categories = data.categories || [];
  }
} catch {}

// Show & Tell is auto-created by tool registration — not user-selectable
categories = categories.filter(c => c.slug !== 'show-and-tell');

const preselectedCat = categories.find(c => c.slug === preselectedCategory);
const pageTitle = preselectedCat ? `New post in ${preselectedCat.name}` : 'New Topic';
---

<BaseLayout title={`${pageTitle} — Forum — Centaur`}>
  <Nav active="forum" />

  <main class="max-w-3xl mx-auto px-6 pt-8 pb-20">
    <div class="flex items-center gap-2 mb-8 text-[13px]">
      <a href="/forum" class="text-secondary hover:text-primary transition-colors">Forum</a>
      {preselectedCat && (
        <>
          <span class="text-quiet">/</span>
          <a href={`/forum/${preselectedCategory}`} class="text-secondary hover:text-primary transition-colors">{preselectedCat.name}</a>
        </>
      )}
      <span class="text-quiet">/</span>
      <span class="text-primary">New</span>
    </div>

    <h1 class="text-3xl font-bold text-primary tracking-tight mb-8">{pageTitle}</h1>

    <form id="new-thread-form" class="space-y-6">
      {preselectedCat ? (
        <input type="hidden" id="thread-category" value={preselectedCategory} />
      ) : (
        <div>
          <label class="block text-[13px] text-secondary mb-1">Category</label>
          <select id="thread-category" required
            class="w-full px-4 py-2.5 bg-surface border border-rule rounded text-primary text-base focus:outline-none focus:border-emphasis transition-colors">
            <option value="">Select a category</option>
            {categories.map(cat => (
              <option value={cat.slug}>{cat.name}</option>
            ))}
          </select>
        </div>
      )}

      <div>
        <label class="block text-[13px] text-secondary mb-1">Title</label>
        <input type="text" id="thread-title" required placeholder="Thread title"
          class="w-full px-4 py-2.5 bg-surface border border-rule rounded text-primary text-base focus:outline-none focus:border-emphasis transition-colors placeholder:text-quiet" />
      </div>

      <div>
        <label class="block text-[13px] text-secondary mb-1">Body</label>
        <textarea id="thread-body" required rows={6} placeholder="What's on your mind?"
          class="w-full px-4 py-2.5 bg-surface border border-rule rounded text-primary text-base focus:outline-none focus:border-emphasis transition-colors placeholder:text-quiet resize-none"></textarea>
      </div>

      <div id="thread-error" class="text-error text-sm hidden"></div>

      <button type="submit" id="thread-submit"
        class="px-5 py-2.5 bg-emphasis font-medium text-sm rounded-md hover:opacity-90 transition-opacity disabled:opacity-40" style="color: #ffffff;">
        Post Topic
      </button>
    </form>
  </main>

  <Footer />

  <script>
    const form = document.getElementById('new-thread-form') as HTMLFormElement;
    const errorEl = document.getElementById('thread-error') as HTMLElement;
    const submitBtn = document.getElementById('thread-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Posting...';

      const category_slug = (document.getElementById('thread-category') as HTMLSelectElement).value;
      const title = (document.getElementById('thread-title') as HTMLInputElement).value.trim();
      const body = (document.getElementById('thread-body') as HTMLTextAreaElement).value.trim();

      if (!category_slug || !title || !body) {
        errorEl.textContent = 'All fields are required.';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Post Topic';
        return;
      }

      try {
        const res = await fetch('/api/forum/threads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, body, category_slug }),
        });

        if (res.status === 401) {
          window.location.href = '/api/auth/login';
          return;
        }

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to create thread');
        }

        const data = await res.json();
        window.location.href = `/forum/thread/${data.id}`;
      } catch (err: any) {
        errorEl.textContent = err.message;
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Post Topic';
      }
    });
  </script>
</BaseLayout>
