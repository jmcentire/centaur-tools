  "invariants": [
    "GITHUB_AUTHORIZE_URL = 'https://github.com/login/oauth/authorize'",
    "GITHUB_TOKEN_URL = 'https://github.com/login/oauth/access_token'",
    "GITHUB_USER_URL = 'https://api.github.com/user'",
    "router prefix = '/api/auth'",
    "router tags = ['auth']",
    "Session cookie key = 'session'",
    "Session cookie is httponly=True, secure=True, samesite='lax'",
    "JWT tokens use settings.jwt_algorithm for encoding/decoding",
    "JWT tokens expire after settings.jwt_expiry_days days",
    "OAuth scope requested: 'read:user user:email'"
  ],
  "requires": [],
  "processing_register": "",
  "data_access": {
    "reads": [
      "users"
    ],
    "writes": [
      "users"
    ],
    "rationale": "Queries User table by github_id; creates new User records for first-time OAuth users; updates avatar_url, display_name, email for existing users",
    "side_effects": [
      {
        "type": "database_query",
        "classification": "read",
        "fields": [
          "User.github_id"
        ],
        "rationale": "Lookup existing user by GitHub ID during OAuth callback"
      },
      {
        "type": "database_insert",
        "classification": "write",
        "fields": [
          "User.github_id",
          "User.username",
          "User.display_name",
          "User.email",
          "User.avatar_url",
          "User.bio"
        ],
        "rationale": "Create new user record on first OAuth login"
      },
      {
        "type": "database_update",
        "classification": "write",
        "fields": [
          "User.avatar_url",
          "User.display_name",
          "User.email"
        ],
        "rationale": "Update user profile fields from GitHub on subsequent logins"
      }
    ]
  },
  "authority": {
    "domains": [
      "authentication",
      "user_sessions",
      "oauth_integration"
    ],
    "rationale": "Owns the authentication flow, session lifecycle, and GitHub OAuth integration logic"
  }
}