          "description": "",
          "validators": []
        },
        {
          "name": "avatar_url",
          "type_ref": "str | None",
          "required": true,
          "default": "",
          "description": "",
          "validators": []
        },
        {
          "name": "bio",
          "type_ref": "str | None",
          "required": true,
          "default": "",
          "description": "",
          "validators": []
        }
      ],
      "item_type": "",
      "variants": [],
